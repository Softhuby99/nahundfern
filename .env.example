# --- Domain ---
PUBLIC_BASE_URL=https://nahundfern.servuswir.de

# --- Postgres ---
DB_USER=nahundfern
DB_PASSWORD=change-me-strong
DB_NAME=nahundfern

# --- App ---
# openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
# Seeding is opt-in. Flip to `true` only for the first boot of a fresh install.
SEED_ON_START=false

# --- Backups ---
# Rolling retention for daily pg_dump snapshots inside the `backup` volume.
BACKUP_KEEP_DAYS=14

# --- TLS (Let's Encrypt) ---
LETSENCRYPT_EMAIL=you@example.com
